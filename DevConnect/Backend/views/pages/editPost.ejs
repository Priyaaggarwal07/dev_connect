<!DOCTYPE html>
<html>
<head>
  <title>Edit Post</title>
</head>
<body>

  <h2>Edit Post</h2>

  <form action="/edit-post/<%= post._id %>" method="POST">
    <input type="text" name="title" value="<%= post.title %>" required />
    <br><br>

    <textarea name="content" required><%= post.content %></textarea>
    <br><br>

    <button type="submit">Update</button>
  </form>

</body>
</html>